# ============================================================
# HanksTank ML — .gitignore
# ============================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/

# IDE & OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ============================================================
# ML Artifacts — binary files, too large for git
# Use GCS (gs://hanks_tank_data/models/) for model storage
# Use data/training/ convention is: rebuild locally or fetch from BQ
# ============================================================
*.pkl
models/
src/catboost_info/

# Training data (binary parquets — regenerated by build_*_features.py)
data/training/
data/2026/

# ============================================================
# Runtime logs — generated output, not source
# Exception: keep experiment result JSON files (structured records)
# ============================================================
logs/2026/
logs/validation/
logs/*.log
# Keep JSON experiment results (small, structured, informative)
!logs/*.json

# ============================================================
# GCP credentials — never commit
# ============================================================
credentials.json
service-account.json
*.json
!package*.json
!logs/*.json
!src/catboost_info/*.json

# Temporary
*.tmp
*.bak
*~
